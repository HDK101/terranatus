[sub_resource type="Shader" id="Shader_gu6gc"]
code = "// NOTE: Shader automatically converted from Godot Engine 4.6.stable.mono's CanvasItemMaterial.

shader_type canvas_item;
render_mode blend_mix;

uniform sampler2D noise_decay;
uniform sampler2D slash_trail_over;
uniform float offset;

void fragment() {
	vec4 texture_color = texture(TEXTURE, UV + vec2(offset, 0.0f));
	vec4 slash_color = texture(slash_trail_over, UV + vec2(offset, 0.0f));
	//vec4 color = texture(TEXTURE, UV);
	float noise_value = texture(noise_decay, UV).r;
	
	vec4 color;
	color = mix(mix(texture_color * 0.6f, slash_color, slash_color.a), vec4(vec3(1.0f), 0.0f), round(noise_value + offset - 0.5f));
	//color.a = alpha * round(noise_value - offset + 0.25f);
	
	COLOR = color;
}"

